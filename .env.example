# Firebase web app config — copy to .env.local and fill with your project's values.
# These are client-side config values (not secrets); access is controlled by
# Firestore/Storage security rules. Do NOT commit .env.local.
VITE_FIREBASE_API_KEY=<API_KEY>
VITE_FIREBASE_AUTH_DOMAIN=<PROJECT_ID>.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=<PROJECT_ID>
VITE_FIREBASE_STORAGE_BUCKET=<PROJECT_ID>.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=<SENDER_ID>
VITE_FIREBASE_APP_ID=<APP_ID>

# Slug shown at the bare domain (/#/ redirects here).
VITE_DEFAULT_MODULE_SLUG=anaphylaxis
